<Window x:Class="csengetes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:csengetes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Csengés" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <StackPanel Width="220" DockPanel.Dock="Left" Margin="10">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse x:Name="dot1" Width="14" Height="14" Fill="#F44336"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="Normál" Width="160" Height="40" FontSize="15"
                        Click="BtnCsengo1_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse x:Name="dot2" Width="14" Height="14" Fill="#F44336"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="Röviditett" Width="160" Height="40" FontSize="15"
                        Click="BtnCsengo2_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="dot3" Width="14" Height="14" Fill="#F44336"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="Rendkivüli" Width="160" Height="40" FontSize="15"
                        Click="BtnCsengo3_Click"/>
                        </StackPanel>

                    </StackPanel>
                </DockPanel>
            </TabItem>
            <TabItem Header="Normál" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                            Margin="10" Padding="20,5" Click="MentesNormal_Click"/>
                    <DataGrid x:Name="datagridNormal" AutoGenerateColumns="True" FontSize="15px"
                              Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>
            <TabItem Header="Röviditett" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                Margin="10" Padding="20,5" Click="MentesRöviditett_Click"/>
                    <DataGrid x:Name="datagridRöviditett" AutoGenerateColumns="True" FontSize="15px"
                  Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>
            <TabItem Header="Rendkivüli" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                            Margin="10" Padding="20,5" Click="MentesRendkivuli_Click" FontSize="30px"/>
                    <DataGrid x:Name="datagridRendkivuli" AutoGenerateColumns="True" FontSize="15px"
                              Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>