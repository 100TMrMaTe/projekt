<Window x:Class="csengetes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:csengetes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl SelectionChanged="TabControl_SelectionChanged">

            <TabItem Header="Csengés" FontSize="20px">
                <Grid Background="#FFE5E5E5" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10"
                            BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,8,0" Padding="16">
                        <StackPanel VerticalAlignment="Center">

                            <TextBlock Text="Csengetések" FontSize="15" Foreground="#9E9E9E"
                                       Margin="0,0,0,12"/>

                            <Button x:Name="btn1" Click="BtnCsengo1_Click" Margin="0,0,0,10"
                                    HorizontalContentAlignment="Left" Padding="14,12"
                                    Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="dot1" Width="10" Height="10" Fill="#F44336"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Normál" FontSize="15" Foreground="#212121"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btn2" Click="BtnCsengo2_Click" Margin="0,0,0,10"
                                    HorizontalContentAlignment="Left" Padding="14,12"
                                    Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="dot2" Width="10" Height="10" Fill="#F44336"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Rövidített" FontSize="15" Foreground="#212121"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btn3" Click="BtnCsengo3_Click"
                                    HorizontalContentAlignment="Left" Padding="14,12"
                                    Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="dot3" Width="10" Height="10" Fill="#F44336"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Rendkívüli" FontSize="15" Foreground="#212121"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1"/>
                </Grid>
            </TabItem>

            <TabItem Header="Normál" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                            Margin="10" Padding="20,5" Click="MentesNormal_Click"/>
                    <DataGrid x:Name="datagridNormal" AutoGenerateColumns="True" FontSize="15px"
                              Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>

            <TabItem Header="Rövidített" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                            Margin="10" Padding="20,5" Click="MentesRöviditett_Click"/>
                    <DataGrid x:Name="datagridRöviditett" AutoGenerateColumns="True" FontSize="15px"
                              Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>

            <TabItem Header="Rendkívüli" FontSize="20px">
                <DockPanel Background="#FFE5E5E5">
                    <Button Content="Mentés" DockPanel.Dock="Bottom" HorizontalAlignment="Right"
                            Margin="10" Padding="20,5" Click="MentesRendkivuli_Click"/>
                    <DataGrid x:Name="datagridRendkivuli" AutoGenerateColumns="True" FontSize="15px"
                              Margin="10" CanUserAddRows="False"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>